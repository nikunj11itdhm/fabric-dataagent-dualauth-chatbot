# ──────────────────────────────────────────────────────────────────────
#  Fabric Data Agent — Dual Auth Chatbot Configuration
#  Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────

# Required — Your Microsoft Entra ID (Azure AD) tenant GUID
AZURE_TENANT_ID=<your-tenant-id>

# Required — App registration client ID (used for both SPN and Device Code)
AZURE_CLIENT_ID=<your-app-registration-client-id>

# Required for SPN auth — App registration client secret
AZURE_CLIENT_SECRET=<your-client-secret>

# Option A (Recommended): Published Data Agent URL from Fabric portal
#   Go to Fabric portal → open your Data Agent → Settings → copy Published URL
DATA_AGENT_URL=<your-published-data-agent-url>

# Option B: Name-based resolution (if you don't have the published URL)
#   The app will resolve these names to IDs via the Fabric REST API
WORKSPACE_NAME=<your-workspace-name>
AGENT_NAME=<your-agent-name>
